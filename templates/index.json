{
  "sections": {
    "hero": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'daily-hero' %}",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "categories": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'daily-categories' %}",
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "collection_intro": {
      "type": "rich-text",
      "blocks": {
        "caption": {
          "type": "caption",
          "settings": {
            "caption": "Our Collection",
            "text_style": "uppercase",
            "text_size": "small"
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Curated for Daily Life",
            "heading_size": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>50 carefully selected pieces — from table linens and cushions to fragrance and eco kitchen essentials.</p>"
          }
        }
      },
      "block_order": ["caption", "heading", "text"],
      "settings": {
        "full_width": false,
        "color_scheme": "scheme-1",
        "desktop_content_position": "center",
        "content_alignment": "center",
        "padding_top": 20,
        "padding_bottom": 20
      }
    },
    "featured_collection": {
      "type": "featured-collection",
      "settings": {
        "title": "",
        "heading_size": "h2",
        "description": "",
        "show_description": false,
        "description_style": "body",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "full_width": false,
        "show_view_all": true,
        "view_all_style": "solid",
        "enable_desktop_slider": false,
        "swipe_on_mobile": false,
        "image_ratio": "adapt",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "quick_add": "none",
        "columns_mobile": "2",
        "padding_top": 20,
        "padding_bottom": 60
      }
    },
    "brand_story": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'daily-brand-story' %}",
        "color_scheme": "scheme-2",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "features": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'daily-features' %}",
        "color_scheme": "scheme-2",
        "padding_top": 0,
        "padding_bottom": 60
      }
    },
    "shipping": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% render 'daily-shipping' %}",
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "newsletter": {
      "type": "newsletter",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Join the Daily Circle",
            "heading_size": "h2"
          }
        },
        "paragraph": {
          "type": "paragraph",
          "settings": {
            "text": "<p>New arrivals, styling tips, and members-only discounts — delivered to your inbox with the same care we put into every product.</p>"
          }
        }
      },
      "block_order": ["heading", "paragraph"],
      "settings": {
        "color_scheme": "scheme-2",
        "full_width": false,
        "padding_top": 60,
        "padding_bottom": 60
      }
    }
  },
  "order": [
    "hero",
    "categories",
    "collection_intro",
    "featured_collection",
    "brand_story",
    "features",
    "shipping",
    "newsletter"
  ]
}
